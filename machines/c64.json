{
  "machines": [

    {
      "id": "c64",
      "displayName": "Commodore 64",
      "licenseClass": "proprietary",
      "bus": { "type": "FlatMemoryBus", "name": "system", "addrBits": 16 },
      "cpu": { "type": "6510", "dataBus": "system", "codeBus": "system" },
      "devices": [
        { "type": "c64_pla",          "name": "PLA",      "baseAddr": null,
          "ramData": "system" },
        { "type": "inline_color_ram", "name": "ColorRAM", "baseAddr": "0xD800", "size": 1024 },
        { "type": "6567",             "name": "VIC-II",   "baseAddr": "0xD000",
          "dmaBus": true, "colorRam": true },
        { "type": "6581",             "name": "SID",      "baseAddr": "0xD400" },
        { "type": "6526",             "name": "CIA1",     "baseAddr": "0xDC00",
          "clockHz": 985248 },
        { "type": "6526",             "name": "CIA2",     "baseAddr": "0xDD00",
          "clockHz": 985248,
          "portAWriteCallback": "vic2_bank_select", "bankSelectTarget": "VIC-II" },
        { "type": "kbd_c64",          "name": "Keyboard", "baseAddr": null }
      ],
      "roms": [
        { "label": "basic",  "path": "roms/c64/basic.bin",  "size": 8192,
          "overlayAddr": null, "writable": false,
          "passToDevice": ["PLA"] },
        { "label": "kernal", "path": "roms/c64/kernal.bin", "size": 8192,
          "overlayAddr": null, "writable": false,
          "passToDevice": ["PLA"] },
        { "label": "char",   "path": "roms/c64/char.bin",   "size": 4096,
          "overlayAddr": null, "writable": false,
          "passToDevice": ["PLA", "VIC-II"] }
      ],
      "signals": [
        { "name": "irq", "type": "shared", "sources": ["VIC-II", "CIA1"] },
        { "name": "nmi", "type": "nmi",    "sources": ["CIA2"] }
      ],
      "plaWiring": {
        "device": "PLA",
        "signals": {
          "loram":  "loram",
          "hiram":  "hiram",
          "charen": "charen"
        }
      },
      "kbdWiring": {
        "device": "Keyboard",
        "colPort": { "device": "CIA1", "port": "A" },
        "rowPort": { "device": "CIA1", "port": "B" }
      },
      "scheduler": { "type": "step_tick", "frameAccumulator": null }
    }

  ]
}
